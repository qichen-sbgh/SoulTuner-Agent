# ============================================================
# Docker 构建忽略文件
# 减少构建上下文体积，加速 docker build
# ============================================================

# 依赖目录
node_modules/
web/node_modules/
web/.next/
__pycache__/
*.pyc

# 数据目录（运行时通过 volume 挂载）；仅放行后端需要的 pipeline 源码
data/*
!data/pipeline/
data/pipeline/*
!data/pipeline/*.py
!data/pipeline/README.md

# 环境和配置
.env
.env.local
*.log

# 版本控制
.git/
.gitignore

# IDE
.vscode/
.idea/
*.swp

# Docker（避免递归）
docker-compose*.yml

# 不需要的大文件
*.dump
*.tar
*.zip
