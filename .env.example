# ================================================================
# SoulTuner Agent — 环境配置模板（复制为 .env 后填写真实 Key）
# ================================================================
# cp .env.example .env
# ================================================================


# ================================================================
# 第一区：模型部署模式（最常改的地方）
# ================================================================

# ---- 主 LLM（推荐解释 / 闲聊 / 偏好提取等所有非意图分析场景）-----
# 可选值: siliconflow | dashscope | google | sglang | vllm | ollama
MAIN_LLM_PROVIDER=dashscope
# qwen3.7-flash 当前在 DashScope 返回 model_not_found；默认使用已验证可用的 qwen3.7-plus
MODEL_NAME=qwen3.7-plus

# ---- 意图分析专用 LLM（Planner）----
# 【API 大模型模式】一次调用输出：意图 + 实体 + 标签 + 内联 HyDE
INTENT_LLM_PROVIDER=dashscope
INTENT_LLM_MODEL=qwen3.7-plus
PLANNER_CACHE_TTL_SECONDS=300
PLANNER_CACHE_MAX_ENTRIES=256

# 【本地小模型模式】切换为本地 SGLang 部署，HyDE 由下游独立生成
# INTENT_LLM_PROVIDER=sglang
# INTENT_LLM_MODEL=local-planner-qwen3-4b-fp8

# ---- HyDE 声学描述生成专用 LLM（本地模式时填写；API 模式留空即可）----
HYDE_LLM_PROVIDER=
HYDE_LLM_MODEL=

# false = 流式 LLM 解释；true = 确定性简短说明（低延迟/评测）
EXPLANATION_FAST_MODE=false


# ================================================================
# 第二区：API 服务商密钥
# ================================================================

# 默认只需要 DashScope 阿里云百炼
DASHSCOPE_API_KEY=你的_DashScope_Key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 其他 provider 是高级可选项：只有在前端高级设置或 .env 中切换 provider 时才需要填写
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_API_KEY=你的_SiliconFlow_Key
SiliconFlow_API_KEY=你的_SiliconFlow_Key
GOOGLE_API_KEY=你的_Google_Gemini_Key
ZHIPU_API_KEY=你的_智谱_Key
TAVILY_API_KEY=你的_Tavily_Key
LANGSMITH_API_KEY=你的_LangSmith_Key

# 火山引擎 / 豆包（Volcengine / Doubao）
# 在 https://console.volcengine.com/ark 创建推理接入点
VOLCENGINE_API_KEY=你的_Volcengine_Key
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3


# ================================================================
# 第三区：本地推理引擎地址（切换为本地模型时使用）
# ================================================================

SGLANG_BASE_URL=http://localhost:8000/v1
# VLLM_BASE_URL=http://localhost:8000/v1
# OLLAMA_BASE_URL=http://localhost:11434/v1


# ================================================================
# 第四区：检索增强开关
# ================================================================

# Cross-Encoder 精排层
# false = 关闭（推荐，RRF + Graph Affinity 已足够）
# true  = 启用（需额外显存，速度变慢）
RERANKER_ENABLED=false
RERANKER_DEVICE=cuda
RERANKER_TOP_K=10
RERANKER_BATCH_SIZE=16


# ================================================================
# 第五区：外部服务地址
# ================================================================

# 项目统一使用 Docker Neo4j
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=你的_Neo4j_密码

SEARXNG_BASE_URL=http://localhost:8888
NETEASE_API_BASE=http://localhost:3000
PORT=3100
GRAPHZEP_BASE_URL=http://localhost:3100
GRAPHZEP_REQUEST_TIMEOUT_SECONDS=3.5
GRAPHZEP_TOTAL_TIMEOUT_SECONDS=4
GRAPHZEP_UNAVAILABLE_TTL_SECONDS=300
API_PORT=8501
NEXT_PUBLIC_API_URL=http://localhost:8501


# ================================================================
# 第六区：其他
# ================================================================

HF_ENDPOINT=https://huggingface.co
# false = 首次启动允许自动下载缺失的文本编码器，保证向量检索可用
# true  = 完全离线，只读本地缓存；需要提前运行 scripts/download_models.py
HF_OFFLINE=false
# 避开 HuggingFace Xet/CAS 下载路径，普通模型权重下载更稳定
HF_HUB_DISABLE_XET=1
# 文搜音后端：muq（宿主/GPU 默认）/ m2d（回退）/ both（实验并行）。Docker CPU 启动会自动覆盖为 m2d。
DENSE_TEXT_AUDIO_BACKEND=muq
# MuQ 默认按需加载；M2D 只作回退时无需启动预热。改为 background 可预热 M2D。
MUSIC_M2D_TEXT_WARMUP=false
# 单路召回超时。MuQ-MuLan 首次冷加载通常需要 15-30 秒。
RECALL_SOURCE_TIMEOUT_SECONDS=60
# 三锚精排语义锚超时；超时后保留声学/个性化排序
TRI_ANCHOR_TEXT_TIMEOUT_SECONDS=8

# Docker Compose volume 挂载：宿主机的音乐数据根目录
# 包含 processed_audio/, mtg_sample/, online_acquired/ 等子目录
MUSIC_DATA_PATH=./data
